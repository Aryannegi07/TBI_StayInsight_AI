PORT=5000

# ── Week 5: PostgreSQL (Supabase) ─────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
#
# DATABASE_URL: pooled connection (via Supabase's PgBouncer, port 6543).
#   Used by the app at runtime. Add "?pgbouncer=true" as shown below.
# DIRECT_URL: direct connection (port 5432).
#   Used only by Prisma when running migrations (migrate dev / migrate deploy).
#
# If you are not using the connection pooler, you can point both variables
# at the same direct connection string.

DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.supabase.co:5432/postgres"

# ── Week 6: Backend Security ──────────────────────────────────────────────────
# JWT_SECRET: long, random string used to sign/verify auth tokens.
#   Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_EXPIRES_IN: token lifetime (e.g. 1d, 12h, 30m).
# FRONTEND_ORIGIN: the ONLY origin CORS will allow to call this API.

JWT_SECRET="replace_with_a_long_random_secret"
JWT_EXPIRES_IN="1d"
FRONTEND_ORIGIN="http://localhost:5173"

# ── Week 6: Google OAuth 2.0 ──────────────────────────────────────────────────
# Optional — leave blank to disable Google sign-in; every other endpoint keeps
# working normally, and GET /api/auth/google will respond 503 instead of
# starting the OAuth flow. Get these from: Google Cloud Console → APIs &
# Services → Credentials → OAuth client ID → Web application.
# GOOGLE_CALLBACK_URL must exactly match the Authorized redirect URI
# registered in Google Cloud Console.

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"
